# ── JJapkin AI 환경변수 ──────────────────────────────
# 이 파일을 복사해서 .env.local 로 저장하세요.
# cp .env.template .env.local

# ── AI API (DeepSeek) ───────────────────────────────
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY="sk-..."
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# ── 데이터베이스 (Supabase) ─────────────────────────
# Supabase 대시보드 → Settings → Database → Connection String → URI
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres"

# ── 대체 AI (OpenAI 호환 — 옵션) ────────────────────
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."

# ── Supabase 클라이언트 (Auth — 매직링크 로그인) ────
# 두 값을 모두 설정하면 이메일 매직링크 로그인이 활성화된다.
# 미설정 시 앱은 익명(브라우저별) 모드로 동작한다.
# Supabase 대시보드 → Authentication → URL Configuration 에
#   Redirect URL: <APP_URL>/auth/callback 를 추가해야 한다.
# NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT].supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJh..."

# ── 앱 설정 ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="JJapkin AI"
